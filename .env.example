MONGODB_URI=mongodb://127.0.0.1:27017/telegram_bot_db
MONGODB_DB_NAME=telegram_bot_db
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=2
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_SOCKET_TIMEOUT_MS=45000

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
PERSONAL_CHAT_ID=your_personal_chat_id_here

# Jira
JIRA_TOKEN=your_jira_token_here

# Verifix API Credentials
VERIFIX_BASE_URL=https://app.verifix.com
VERIFIX_CLIENT_ID=your_client_id_here
VERIFIX_CLIENT_SECRET=your_client_secret_here
VERIFIX_PROJECT_CODE=your_project_code_here
VERIFIX_FILIAL_ID=your_filial_id_here
